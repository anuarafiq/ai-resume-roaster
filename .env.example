# Groq API key used by lib/groq.js to generate resume feedback.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Postgres connection strings for Prisma, pointing at a Supabase project.
# Project Settings > Database in your Supabase dashboard.
#
# DATABASE_URL: pooled connection (port 6543, pgbouncer) - used at runtime by
# lib/db.js. Required flag: pgbouncer=true.
#   DATABASE_URL="postgresql://<user>:<password>@<host>:6543/postgres?pgbouncer=true&connection_limit=1"
#
# DIRECT_URL: unpooled connection (port 5432) - used by `prisma migrate` /
# `prisma db push`, which don't work through the pgbouncer pooler.
#   DIRECT_URL="postgresql://<user>:<password>@<host>:5432/postgres"
DATABASE_URL=
DIRECT_URL=

# Google OAuth credentials for NextAuth (pages/api/auth/[...nextauth].js).
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <your-app-url>/api/auth/callback/google
# (add both http://localhost:3000/api/auth/callback/google for local dev
# and the production Vercel URL once deployed)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Random secret NextAuth uses to sign session tokens. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# Canonical URL of the deployed app. Required in production; NextAuth uses it
# to build OAuth callback/redirect URLs correctly.
#   Local:      http://localhost:3000
#   Production: https://<your-app>.vercel.app
NEXTAUTH_URL=
